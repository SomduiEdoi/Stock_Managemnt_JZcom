generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  ADMIN
  STOCK_CONTROLLER
  USER
}

enum OrganizationLevel {
  EXECUTIVE
  MANAGER
  SUPERVISOR
  STAFF
}

enum OrganizationTag {
  BSD_MANAGER
  BSD_STAFF
  SCN_MANAGER
  S1_SUPERVISOR
  S1_STAFF
  N1_SUPERVISOR
  N1_STAFF
  C1_SUPERVISOR
  C1_STAFF
  DL_MANAGER
  DL_STAFF
  EN_MANAGER
  CMS_SUPERVISOR
  CMS_STAFF
  SD_SUPERVISOR
  SD_STAFF
}

enum ProjectTag {
  LEAD_PROJECT
  TEAM_MEMBER
}

enum StockControllerTag {
  HEAD_STOCK_CONTROLLER
  STOCK_CONTROLLER
}

enum AssetTrackMethod {
  SERIAL
  QUANTITY
}

enum AssetStatus {
  READY
  REQUEST
  BORROW
  USING
  SOLD
  FAIL
  LOST
  NEED_CHECK
}

enum AssetActionType {
  CREATE
  REQUEST_HOLD
  REQUEST_SUBMIT
  STATUS_CHANGE
  RETURN
  MARK_FAIL
  MARK_LOST
  MARK_NEED_CHECK
  ADJUST_QUANTITY
  IMPORT
}

enum TransactionType {
  BORROW
  USING
  SOLD
}

enum TransactionStatus {
  BORROWED
  RETURNED
  OVERDUE
  ACTIVE
  COMPLETED
}

enum TransactionWorkflowStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MigrationStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum MigrationRowStatus {
  PENDING
  IMPORTED
  FAILED
  SKIPPED
  NEEDS_REVIEW
}

model User {
  id                       String                 @id @default(uuid()) @db.Uuid
  name                     String
  email                    String                 @unique
  passwordHash             String?                @map("password_hash")
  azureAdObjectId          String?                @unique @map("azure_ad_object_id")
  position                 String?
  organizationLevel        OrganizationLevel?     @map("organization_level")
  organizationTag          OrganizationTag?       @map("organization_tag")
  projectTag               ProjectTag?            @map("project_tag")
  stockControllerTag       StockControllerTag?    @map("stock_controller_tag")
  signatureDataUrl         String?                @map("signature_data_url")
  signatureUploadedAt      DateTime?              @map("signature_uploaded_at")
  signatureUploadedById    String?                @map("signature_uploaded_by") @db.Uuid
  lastLoginAt              DateTime?              @map("last_login_at")
  isActive                 Boolean                @default(true) @map("is_active")
  createdAt                DateTime               @default(now()) @map("created_at")
  updatedAt                DateTime               @updatedAt @map("updated_at")
  roles                    UserRole[]
  signatureUploadedBy      User?                  @relation("UserSignatureUploadedBy", fields: [signatureUploadedById], references: [id], onDelete: SetNull)
  uploadedSignatures       User[]                 @relation("UserSignatureUploadedBy")
  domainPermissions        UserDomainPermission[]
  requestLockedAssets      Asset[]                @relation("AssetRequestLockedBy")
  createdAssets            Asset[]                @relation("AssetCreatedBy")
  updatedAssets            Asset[]                @relation("AssetUpdatedBy")
  statusHistories          AssetStatusHistory[]
  requestedTransactions    Transaction[]          @relation("TransactionRequestedBy")
  createdTransactions      Transaction[]          @relation("TransactionCreatedBy")
  returnedTransactionItems TransactionItem[]      @relation("TransactionItemReturnedBy")
  assetReservations        AssetReservation[]
  migrationBatches         MigrationBatch[]
  approvals                TransactionApproval[]

  @@map("users")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  code        RoleCode   @unique
  name        String
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model AssetDomain {
  id              String                 @id @default(uuid()) @db.Uuid
  code            String                 @unique
  prefix          String                 @unique @map("domain_prefix")
  name            String
  inventoryFamily AssetTrackMethod       @default(SERIAL) @map("inventory_family")
  description     String?
  isActive        Boolean                @default(true) @map("is_active")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  permissions     UserDomainPermission[]
  categories      AssetCategory[]
  models          AssetModel[]
  assets          Asset[]

  @@map("asset_domains")
}

model UserDomainPermission {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  domainId  String      @map("domain_id") @db.Uuid
  canView   Boolean     @default(true) @map("can_view")
  canManage Boolean     @default(false) @map("can_manage")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain    AssetDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([userId, domainId])
  @@index([domainId])
  @@map("user_domain_permissions")
}

model AssetCategory {
  id          String       @id @default(uuid()) @db.Uuid
  domainId    String       @map("domain_id") @db.Uuid
  name        String
  description String?
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  domain      AssetDomain  @relation(fields: [domainId], references: [id])
  models      AssetModel[]
  types       AssetType[]

  @@unique([domainId, name])
  @@index([domainId])
  @@map("asset_categories")
}

model AssetType {
  id          String           @id @default(uuid()) @db.Uuid
  categoryId  String           @map("category_id") @db.Uuid
  name        String
  code        String?          @map("type_code")
  trackMethod AssetTrackMethod @default(SERIAL) @map("track_method")
  description String?
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  category    AssetCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  models      AssetModel[]

  @@unique([categoryId, name])
  @@unique([categoryId, code])
  @@index([categoryId])
  @@map("asset_types")
}

model AssetModel {
  id          String         @id @default(uuid()) @db.Uuid
  domainId    String         @map("domain_id") @db.Uuid
  categoryId  String?        @map("category_id") @db.Uuid
  assetTypeId String?        @map("asset_type_id") @db.Uuid
  name        String
  brand       String?
  modelNo     String?        @map("model_no")
  partNo      String?        @map("part_no")
  typeName    String?        @map("type_name")
  description String?
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  domain      AssetDomain    @relation(fields: [domainId], references: [id])
  category    AssetCategory? @relation(fields: [categoryId], references: [id])
  assetType   AssetType?     @relation(fields: [assetTypeId], references: [id])
  assets      Asset[]

  @@index([domainId])
  @@index([categoryId])
  @@index([assetTypeId])
  @@index([name])
  @@map("asset_models")
}

model Location {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  code        String?  @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  assets      Asset[]

  @@map("locations")
}

model Asset {
  id                String               @id @default(uuid()) @db.Uuid
  assetModelId      String               @map("asset_model_id") @db.Uuid
  domainId          String               @map("domain_id") @db.Uuid
  locationId        String?              @map("location_id") @db.Uuid
  serialNo          String?              @unique @map("serial_no")
  assetNo           String?              @map("asset_no")
  stockCode         String?              @map("stock_code")
  status            AssetStatus
  note              String?
  imageRef          String?              @map("image_ref")
  assetQuantity     Int                  @default(1) @map("asset_quantity")
  legacyQty         Int?                 @map("legacy_qty")
  legacyFg          Int?                 @map("legacy_fg")
  locationText      String?              @map("location_text")
  sourceSystem      String?              @map("source_system")
  sourceRecordId    String?              @map("source_record_id")
  migrationBatchId  String?              @map("migration_batch_id") @db.Uuid
  requestLockedById String?              @map("request_locked_by") @db.Uuid
  requestLockedAt   DateTime?            @map("request_locked_at")
  isActive          Boolean              @default(true) @map("is_active")
  createdById       String?              @map("created_by") @db.Uuid
  updatedById       String?              @map("updated_by") @db.Uuid
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  assetModel        AssetModel           @relation(fields: [assetModelId], references: [id])
  domain            AssetDomain          @relation(fields: [domainId], references: [id])
  location          Location?            @relation(fields: [locationId], references: [id])
  migrationBatch    MigrationBatch?      @relation(fields: [migrationBatchId], references: [id])
  requestLockedBy   User?                @relation("AssetRequestLockedBy", fields: [requestLockedById], references: [id], onDelete: SetNull)
  createdBy         User?                @relation("AssetCreatedBy", fields: [createdById], references: [id])
  updatedBy         User?                @relation("AssetUpdatedBy", fields: [updatedById], references: [id])
  statusHistories   AssetStatusHistory[]
  transactionItems  TransactionItem[]
  migrationRows     MigrationRow[]
  reservations      AssetReservation[]

  @@index([domainId])
  @@index([status])
  @@index([locationId])
  @@index([assetModelId])
  @@index([sourceRecordId])
  @@index([stockCode])
  @@index([requestLockedById])
  @@map("assets")
}

model AssetReservation {
  id        String   @id @default(uuid()) @db.Uuid
  assetId   String   @map("asset_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  quantity  Int      @default(1)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assetId, userId])
  @@index([assetId])
  @@index([userId])
  @@map("asset_reservations")
}

model AssetStatusHistory {
  id               String          @id @default(uuid()) @db.Uuid
  assetId          String          @map("asset_id") @db.Uuid
  transactionId    String?         @map("transaction_id") @db.Uuid
  fromStatus       AssetStatus?    @map("from_status")
  toStatus         AssetStatus     @map("to_status")
  actionType       AssetActionType @map("action_type")
  note             String?
  previousQuantity Int?            @map("previous_quantity")
  newQuantity      Int?            @map("new_quantity")
  changedById      String          @map("changed_by") @db.Uuid
  changedAt        DateTime        @default(now()) @map("changed_at")
  asset            Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  transaction      Transaction?    @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  changedBy        User            @relation(fields: [changedById], references: [id])

  @@index([assetId])
  @@index([transactionId])
  @@index([toStatus])
  @@index([changedAt])
  @@index([changedById])
  @@map("asset_status_histories")
}

model Transaction {
  id                  String                    @id @default(uuid()) @db.Uuid
  transactionNo       String?                   @unique @map("transaction_no")
  sourceTransactionId String?                   @map("source_transaction_id") @db.Uuid
  type                TransactionType
  status              TransactionStatus
  workflowStatus      TransactionWorkflowStatus @default(COMPLETED) @map("workflow_status")
  purpose             String
  note                String?
  documentRef         String?                   @map("document_ref")
  requestDate         DateTime                  @default(now()) @map("request_date")
  dueDate             DateTime?                 @map("due_date")
  internalRequest     Boolean                   @default(false) @map("internal_request")
  serviceRequest      Boolean                   @default(false) @map("service_request")
  projectRequest      Boolean                   @default(false) @map("project_request")
  soldPrice           Decimal?                  @map("sold_price") @db.Decimal(12, 2)
  requestedById       String                    @map("requested_by") @db.Uuid
  createdById         String                    @map("created_by") @db.Uuid
  returnedAt          DateTime?                 @map("returned_at")
  completedAt         DateTime?                 @map("completed_at")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  requestedBy         User                      @relation("TransactionRequestedBy", fields: [requestedById], references: [id])
  createdBy           User                      @relation("TransactionCreatedBy", fields: [createdById], references: [id])
  sourceTransaction   Transaction?              @relation("TransactionSource", fields: [sourceTransactionId], references: [id], onDelete: SetNull)
  derivedTransactions Transaction[]             @relation("TransactionSource")
  items               TransactionItem[]
  statusHistories     AssetStatusHistory[]
  approvals           TransactionApproval[]

  @@index([type])
  @@index([status])
  @@index([workflowStatus])
  @@index([sourceTransactionId])
  @@index([requestedById])
  @@index([createdById])
  @@index([dueDate])
  @@index([requestDate])
  @@map("transactions")
}

model TransactionItem {
  id                String       @id @default(uuid()) @db.Uuid
  transactionId     String       @map("transaction_id") @db.Uuid
  assetId           String       @map("asset_id") @db.Uuid
  fromStatus        AssetStatus? @map("from_status")
  toStatus          AssetStatus  @map("to_status")
  requestedQuantity Int          @default(1) @map("requested_quantity")
  note              String?
  resolvedStatus    AssetStatus? @map("resolved_status")
  resolutionNote    String?      @map("resolution_note")
  soldPrice         Decimal?     @map("sold_price") @db.Decimal(12, 2)
  returnedAt        DateTime?    @map("returned_at")
  returnedById      String?      @map("returned_by") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  transaction       Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  asset             Asset        @relation(fields: [assetId], references: [id], onDelete: Restrict)
  returnedBy        User?        @relation("TransactionItemReturnedBy", fields: [returnedById], references: [id], onDelete: SetNull)

  @@unique([transactionId, assetId])
  @@index([assetId])
  @@index([transactionId])
  @@index([returnedById])
  @@index([resolvedStatus])
  @@map("transaction_items")
}

model TransactionApproval {
  id                   String         @id @default(uuid()) @db.Uuid
  transactionId        String         @map("transaction_id") @db.Uuid
  userId               String?        @map("user_id") @db.Uuid
  stepSequence         Int            @map("approval_step_sequence")
  requiredTag          String         @map("approval_required_tag")
  approverNameSnapshot String?        @map("approver_name_snapshot")
  approverTagSnapshot  String?        @map("approver_tag_snapshot")
  actedAt              DateTime?      @map("approval_acted_at")
  comment              String?        @map("approval_comment")
  status               ApprovalStatus @default(PENDING) @map("approval_status")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  transaction          Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user                 User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([userId])
  @@index([status])
  @@index([stepSequence])
  @@map("transaction_approvals")
}

model MigrationBatch {
  id           String          @id @default(uuid()) @db.Uuid
  sourceSystem String          @default("SharePoint") @map("source_system")
  fileName     String?         @map("file_name")
  status       MigrationStatus
  totalRows    Int             @default(0) @map("total_rows")
  successRows  Int             @default(0) @map("success_rows")
  failedRows   Int             @default(0) @map("failed_rows")
  createdById  String          @map("created_by") @db.Uuid
  createdAt    DateTime        @default(now()) @map("created_at")
  completedAt  DateTime?       @map("completed_at")
  createdBy    User            @relation(fields: [createdById], references: [id])
  rows         MigrationRow[]
  assets       Asset[]

  @@map("migration_batches")
}

model MigrationRow {
  id               String             @id @default(uuid()) @db.Uuid
  migrationBatchId String             @map("migration_batch_id") @db.Uuid
  rowNumber        Int                @map("row_number")
  rawData          Json               @map("raw_data")
  mappedData       Json?              @map("mapped_data")
  status           MigrationRowStatus
  errorMessage     String?            @map("error_message")
  assetId          String?            @map("asset_id") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at")
  migrationBatch   MigrationBatch     @relation(fields: [migrationBatchId], references: [id], onDelete: Cascade)
  asset            Asset?             @relation(fields: [assetId], references: [id])

  @@index([migrationBatchId])
  @@index([assetId])
  @@map("migration_rows")
}
